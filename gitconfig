[user]
	name = Kjetil Valle
	email = kjetil.valle@gmail.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIA35JFxy9iET4iVoWDC0SGfWaOUbVSHg7673EKUVcUQP
[color]
    diff = auto
    status = auto
    branch = auto
[core]
	editor = vim +2
	pager = diff-so-fancy | less --tabs=4 -RF
    whitespace = fix,space-before-tab,tab-in-indent,trailing-space,blank-at-eof
	autocrlf = false
	hooksPath = ~/.githooks
[push]
    default = current
[github]
    user = kvalle
[alias]
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
    wdiff = diff --color-words
    st = status -s
    rank = shortlog -sn --no-merges
    praise = blame
    w = whatchanged --oneline
    s = switch
    r = restore
    co = checkout
    pr = pull --rebase
	pf = push --force-with-lease
    cm = "!f() { \
        if git show-ref --quiet refs/heads/main; then \
            git checkout main; \
        elif git show-ref --quiet refs/heads/master; then \
            git checkout master; \
        else \
            echo 'Fant verken main eller master branch i repoet 🤷'; \
            return 1; \
        fi; \
    }; f"
[hub]
    protocol = https
[rerere]
    enabled = true
[clean]
    requireForce = false
[init]
	defaultBranch = main
[interactive]
	diffFilter = diff-so-fancy --patch
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	func = 146 bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
	allowedSignersFile = ~/dotfiles/git/allowed_signers
[commit]
	gpgsign = true
	template = ~/dotfiles/gitmessage

[includeIf "gitdir:~/dev/digipost/"]
	path = ~/dev/digipost/.gitconfig
