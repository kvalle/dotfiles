{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  
  "theme": "dark",

  "notifications": false,
  "notificationMethod": "notifications_disabled",
  
  "defaultMode": "plan",
  
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [""]
  },
  "spinnerTipsEnabled": false,
  "prefersReducedMotion": true
}