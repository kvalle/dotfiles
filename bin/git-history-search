#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# git-history-search – søk i git-historikken (pickaxe)
# ---------------------------------------------------------------------------

_c_bold=$'\e[1m'
_c_dim=$'\e[2m'
_c_reset=$'\e[0m'
_c_green=$'\e[32m'
_c_red=$'\e[31m'
_c_yellow=$'\e[33m'
_c_blue=$'\e[34m'

print_help() {
  cat <<EOF
${_c_bold}git history-search${_c_reset} ${_c_dim}–${_c_reset} søk i git-historikken (pickaxe)

Finner alle commits der en tekststreng ble lagt til eller fjernet (git log -S),
og viser diff-utdraget med treffet uthevet.

${_c_bold}Bruk:${_c_reset}
  ${_c_green}git history-search${_c_reset} ${_c_yellow}<søkestreng>${_c_reset}
  ${_c_green}git history-search${_c_reset} ${_c_yellow}<søkestreng>${_c_reset} ${_c_yellow}<kontekst>${_c_reset}

${_c_bold}Argumenter:${_c_reset}
  ${_c_yellow}<søkestreng>${_c_reset}       Teksten det søkes etter ${_c_dim}(git log -S)${_c_reset}
  ${_c_yellow}<kontekst>${_c_reset}         Antall kontekstlinjer ${_c_dim}(standard: 0)${_c_reset}
  ${_c_yellow}-h${_c_reset}                 Vis denne hjelpeteksten

${_c_bold}Eksempel:${_c_reset}
  ${_c_green}git hs${_c_reset} ${_c_yellow}"TODO"${_c_reset} ${_c_yellow}3${_c_reset}    ${_c_dim}Finn commits som la til/fjernet "TODO", vis 3 linjer kontekst${_c_reset}
EOF
}

case "${1:-}" in
  -h|--help) print_help; exit 0 ;;
esac

if [[ -z "${1:-}" ]]; then
  echo "Mangler søkestreng." >&2
  echo >&2
  print_help >&2
  exit 1
fi

search="$1"
context="${2:-0}"

# Samle commits der strengen ble lagt til/fjernet
mapfile -t commits < <(git log -S"$search" --format="%H")

if [[ ${#commits[@]} -eq 0 ]]; then
  echo "${_c_dim}Ingen treff for${_c_reset} \"$search\" ${_c_dim}i historikken.${_c_reset}" >&2
  exit 0
fi

# Produser output, pipe gjennom pager
{
  for i in "${!commits[@]}"; do
    commit_id="${commits[$i]}"

    # Separator mellom commits (ikke før første)
    if [[ $i -gt 0 ]]; then
      echo
      echo "${_c_dim}───────────────────────────────────────────────────${_c_reset}"
      echo
    fi

    # Commit-info: hash, forfatter, dato, melding
    git log -1 --format="${_c_bold}${_c_blue}%H${_c_reset}%n${_c_yellow}%an${_c_reset} ${_c_dim}%ar${_c_reset}%n%s" "$commit_id"
    echo

    # Diff-utdrag: viser kun filer med treff, filnavn dimmet, treff uthevet
    git show --format="" "$commit_id" \
      | awk -v pat="$search" -v ctx="$context" \
            -v dim="${_c_dim}" -v reset="${_c_reset}" \
            -v hi="${_c_bold}${_c_green}" \
            -v clr_add="${_c_green}" -v clr_del="${_c_red}" '
          /^diff --git/ {
            if (match_found) flush()
            header=$0; delete lines; n=0; match_found=0
            delete match_idx
            next
          }
          {
            lines[++n]=$0
            if (index($0, pat)) { match_found=1; match_idx[n]=1 }
          }
          END { if (match_found) flush() }

          function flush(    i, start, end, printed, sep) {
            printf "%s%s%s\n", dim, header, reset
            if (ctx == 0) {
              for (i=1; i<=n; i++)
                if (i in match_idx) print colorize(highlight(lines[i], hicolor(lines[i])))
            } else {
              printed=0
              for (i=1; i<=n; i++) {
                start=i-ctx; end=i+ctx
                if (i in match_idx) {
                  if (start<1) start=1
                  if (end>n) end=n
                  if (printed && start > printed+1) print "  --"
                  for (sep=start; sep<=end; sep++) {
                    if (sep > printed) {
                      if (sep in match_idx) print colorize(highlight(lines[sep], hicolor(lines[sep])))
                      else print colorize(lines[sep])
                    }
                  }
                  if (end > printed) printed=end
                }
              }
            }
          }

          function hicolor(line) {
            if (line ~ /^-/) return "\033[1m" clr_del
            return hi
          }

          function highlight(line, color,    out, before, pos, plen) {
            out=""; plen=length(pat)
            while ((pos=index(line, pat)) > 0) {
              before=substr(line, 1, pos-1)
              out = out before color pat reset
              line=substr(line, pos+plen)
            }
            return out line
          }

          function colorize(line) {
            if (line ~ /^\+/) return clr_add "+" reset substr(line, 2)
            if (line ~ /^-/)  return clr_del "-" reset substr(line, 2)
            return line
          }
        ' \
      || true
  done
} | ${GIT_PAGER:-less -R}
