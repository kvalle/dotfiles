#!/usr/bin/env bash
set -euo pipefail

skip_tests=true
module=""
test_filter=""

print_help() {
  cat <<'EOF'
mci · kjør 'mvn clean install' med støtte for modulbygg og enkelttester

Bruk:
  mci                              # Full bygg, uten tester
  mci -t                           # Full bygg, med tester
  mci <modul>                      # Modulbygg, uten tester
  mci <modul> -t                   # Modulbygg, med alle tester
  mci <modul> <Test>               # Kjør enkelt testklasse
  mci <modul> <Test#metode>        # Kjør enkelt testmetode

Flagg:
  -t, --test              Kjør tester
  -h, --help              Vis denne hjelpen

Testfilter-eksempler:
  mci dpost-web-server SendForsendelseConcurrencyIT
  mci dpost-web-server 'SendForsendelseConcurrencyIT#metodeNavn'
  mci dpost-web-server 'SendForsendelseConcurrencyIT#samtidig_*'

Når testfilter er oppgitt kjøres tester automatisk (uten behov for -t):
  mvn clean install -pl <modul> -am -Dtest='<filter>' -Dsurefire.failIfNoSpecifiedTests=false

EOF
}

# Argument-parsing
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) print_help; exit 0 ;;
    -t|--test) skip_tests=false; shift ;;
    --) shift; break ;;
    -*) echo "Ukjent flagg: $1" >&2; exit 2 ;;
    *)  if [[ -z "$module" ]]; then
          module="$1"; shift
        elif [[ -z "$test_filter" ]]; then
          test_filter="$1"; shift
        else
          echo "For mange argumenter." >&2; exit 2
        fi
        ;;
  esac
done

# Validering
if [[ -n "$test_filter" && -z "$module" ]]; then
  echo "Feil: Testfilter krever at modul er oppgitt." >&2
  exit 2
fi

# Testfilter impliserer at tester skal kjøres
if [[ -n "$test_filter" ]]; then
  skip_tests=false
fi

# Kjøring
cmd=(mvn clean install)
if [[ -n "$module" ]]; then
  cmd+=(-pl "$module" -am)
fi
if [[ "$skip_tests" == true ]]; then
  cmd+=(-DskipTests)
fi
if [[ -n "$test_filter" ]]; then
  cmd+=(-Dtest="$test_filter" -Dsurefire.failIfNoSpecifiedTests=false)
fi
exec "${cmd[@]}"
